{
  "name": "@virtality/nodemailer",
  "version": "0.0.0",
  "description": "Nodemailer for the Virtality platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "nodemailer": "8.0.1",
    "@react-email/render": "2.0.0",
    "react": "19.2.3",
    "@virtality/ui": "workspace:*",
    "@virtality/shared": "workspace:*",
    "@virtality/db": "workspace:*"
  },
  "devDependencies": {
    "@virtality/typescript-config": "workspace:*",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/nodemailer": "7.0.11",
    "typescript": "5.9.3"
  }
}
