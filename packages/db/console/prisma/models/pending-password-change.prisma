model PendingPasswordChange {
  id                  String                      @id @default(cuid())
  userId              String
  kind                PendingPasswordChangeKind
  status              PendingPasswordChangeStatus @default(PENDING)
  pendingPasswordHash String
  approvalTokenHash   String
  initiatingSessionId String?
  destinationEmail    String
  expiresAt           DateTime                    @db.Timestamp(6)
  createdAt           DateTime                    @default(now()) @db.Timestamp(6)
  approvedAt          DateTime?                   @db.Timestamp(6)
  cancelledAt         DateTime?                   @db.Timestamp(6)
  supersededAt        DateTime?                   @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "pending_password_change_userId_fkey")

  @@index([userId, status], map: "pending_password_change_userId_status_idx")
  @@index([approvalTokenHash], map: "pending_password_change_approvalTokenHash_idx")
}
